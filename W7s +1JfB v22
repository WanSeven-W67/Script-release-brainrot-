-- AMAN DATA CONSTRAINTS CLEANSING
local function cleanOldConstraints(hrp)
    if not hrp then return end
    for _, child in pairs(hrp:GetChildren()) do
        if child:IsA("BodyVelocity") or child:IsA("BodyGyro") then
            child:Destroy()
        end
    end
end

local function getFreshRoot()
    local char = player.Character
    if not char then return nil end
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") then part.Anchored = false end
    end
    return char:FindFirstChild("HumanoidRootPart")
end

-- TWEEN MANAGER WITH TIMEOUT OVERRIDE
local function safeTween(hrp, targetCFrame, duration)
    if not hrp then return end
    local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    local completed = false
    
    local connection
    connection = tween.Completed:Connect(function()
        completed = true
        if connection then connection:Disconnect() end
    end)
    
    tween:Play()
    
    local startTime = tick()
    while not completed and (tick() - startTime) < 5 do
        if not hrp or not hrp.Parent then break end
        task.wait()
    end
    
    if not completed and tween then
        tween:Cancel()
        tween:Destroy()
    end
    
    if hrp and hrp.Parent then
        hrp.CFrame = targetCFrame
    end
end

-- NAVIGASI PULAU REGULER DENGAN CONTINUOUS VELOCITY LOCK ENGINE (ANTI-ANJLOK)
local function tweenTo(targetPos)
    pcall(function()
        _G.IsTweening = true
        if floatPart then floatPart.Transparency = 1 floatPart.CanCollide = false end
        
        local currentSpeed = tonumber(_G.TweenSpeed) or 250
        local hrp = getFreshRoot()
        if not hrp then _G.IsTweening = false return end
        
        cleanOldConstraints(hrp)
        
        local masterBV = Instance.new("BodyVelocity")
        masterBV.Velocity = Vector3.new(0, 0, 0)
        masterBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        masterBV.Parent = hrp
        
        -- TAHAP 1: Masuk Jalur Tikus (X: 75, Y: 80)
        local stage1Pos = Vector3.new(75, 80, hrp.Position.Z)
        safeTween(hrp, CFrame.new(stage1Pos), (hrp.Position - stage1Pos).Magnitude / currentSpeed)
        
        hrp = getFreshRoot()
        if not hrp then if masterBV then masterBV:Destroy() end _G.IsTweening = false return end
        masterBV.Parent = hrp
        
        -- TAHAP 2: Meluncur Sepanjang Sumbu Z Terowongan Dinding
        local stage2Pos = Vector3.new(75, 80, targetPos.Z)
        safeTween(hrp, CFrame.new(stage2Pos), math.abs(hrp.Position.Z - targetPos.Z) / currentSpeed)
        
        hrp = getFreshRoot()
        if not hrp then if masterBV then masterBV:Destroy() end _G.IsTweening = false return end
        masterBV.Parent = hrp
        
        -- TAHAP 3: Keluar Dinding Mendarat Presisi Ke Target Pulau Asli
        local tweenEnd = TweenService:Create(hrp, TweenInfo.new((hrp.Position - targetPos).Magnitude / currentSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = CFrame.new(targetPos)})
        tweenEnd:Play()
        tweenEnd.Completed:Wait()
        
        if masterBV then masterBV:Destroy() end
        
        if _G.FloatActive and hrp then
            lockedY = hrp.Position.Y - 3.5
            if floatPart then
                floatPart.CFrame = CFrame.new(hrp.Position.X, lockedY, hrp.Position.Z)
                floatPart.Transparency = 0.5
                floatPart.CanCollide = true
            end
        end
        _G.IsTweening = false
    end)
end

